{
  "name": "@tordans/changelog-kit",
  "version": "0.1.0",
  "description": "Shared changelog scripts and React list component to manage and generate user facing changelogs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tordans/changelog-kit.git"
  },
  "bin": {
    "changelog-kit-build": "./dist/cli/build.js",
    "changelog-kit-prefill": "./dist/cli/prefill.js",
    "changelog-kit-verify": "./dist/cli/verify.js"
  },
  "files": [
    "dist",
    "README.md",
    ".cursor/skills",
    ".cursor/skills/changelog-update/SKILL.reference.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./styles": {
      "default": "./dist/react/styles.css"
    }
  },
  "scripts": {
    "build": "tsup && bun run build:styles",
    "build:styles": "tailwindcss -i ./src/react/styles.css -o ./dist/react/styles.css --minify",
    "check": "bun run format:check && bun run lint && bun run typecheck",
    "format": "oxfmt -c oxfmt.config.mjs --write .",
    "format:check": "oxfmt -c oxfmt.config.mjs --check .",
    "lint": "oxlint -c oxlint.config.mjs .",
    "prepare": "husky",
    "typecheck": "tsgo --noEmit",
    "verify:dist": "bun run build && git diff --quiet -- dist || (echo 'dist is out of date. Run bun run build and commit dist.' && exit 1)"
  },
  "dependencies": {
    "micromark": "^4.0.2",
    "yaml": "^2.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@typescript/native-preview": "^7.0.0-dev.20260427.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "agents": {
    "skills": [
      {
        "name": "changelog-update",
        "path": "./.cursor/skills/changelog-update"
      }
    ]
  },
  "agentskills": {
    "skills": [
      {
        "name": "changelog-update",
        "path": "./.cursor/skills/changelog-update"
      }
    ]
  }
}
